      "id": "set-content-brief",
      "name": "Set Content Brief",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [450, 300]
    },
    {
      "parameters": {
        "url": "https://api.unsplash.com/search/photos",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Client-ID {{$credentials.unsplashAccessKey}}"
            }
          ]
        },
        "queryParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "={{$json.topic}}"
            },
            {
              "name": "per_page",
              "value": 5
            },
            {
              "name": "orientation",
              "value": "portrait"
            }
          ]
        },
        "options": {}
      },
      "id": "unsplash-search",
      "name": "Search Unsplash Photos",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [650, 300],
      "credentials": {
        "unsplashAccessKey": {
          "id": "1",
          "name": "Unsplash API"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Pick the best Unsplash photo\nconst results = $input.first().json.results;\nif (!results || results.length === 0) {\n  return [{ json: {} }];\n}\n\n// Pick highest rated photo\nconst best = results.reduce((prev, curr) => \n  (curr.likes || 0) > (prev.likes || 0) ? curr : prev\n, results[0]);\n\nreturn [{\n  json: {\n    unsplash_image_url: best.urls?.regular || best.urls?.small,\n    unsplash_author: best.user?.name,\n    unsplash_author_url: best.user?.links?.html,\n    unsplash_alt: best.alt_description,\n    image_prompt: $input.first().json.topic\n  }\n}];"
      },
      "id": "pick-photo",
      "name": "Pick Best Photo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2.4,
      "position": [850, 300]
    },
    {
      "parameters": {
        "model": "llama3.1:8b",
        "prompt": "You are an expert Instagram content creator. Generate engaging carousel content.\n\nTopic: {{$json.topic}}\nAngle: {{$json.angle}}\nFormat: {{$json.format}}\n\nGenerate:\n1. A hook (attention-grabbing first line)\n2. 5 slides with title and content\n3. A caption\n4. 10 relevant hashtags\n\nReturn JSON:\n{\"hook\":\"string\",\"slides\":[{\"title\":\"string\",\"content\":\"string\"}],\"caption\":\"string\",\"hashtags\":[\"string\"]}"
      },
      "id": "ollama-generate",
      "name": "Generate with Ollama",
      "type": "ollama.ollamaLlm",
      "typeVersion": 1,
      "position": [1050, 300],
      "credentials": {
        "ollama": {
          "id": "1",
          "name": "Ollama Local"
        }
      }
    },
    {
      "parameters": {
        "url": "=https://{{$json.supabaseProject}}.supabase.co/rest/v1/instagram_drafts",
        "authentication": "genericCredentialType",
