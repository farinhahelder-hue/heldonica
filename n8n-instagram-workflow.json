{
  "name": "Instagram Carousel - Planifié",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{"field": "hours", "hoursInterval": 1}]
        }
      },
      "id": "schedule-trigger",
      "name": "Planificateur",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [250, 300]
    },
    {
      "parameters": {
        "values": {
          "string": [
            { "name": "topic", "value": "que faire a paris" },
            { "name": "angle", "value": "authentique et insolite" },
            { "name": "format", "value": "carousel" },
            { "name": "cta", "value": "Partagez en commentaire! 👇" }
          ]
        }
      },
      "id": "set-brief",
      "name": "Brief",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [450, 300]
    },
    {
      "parameters": {
        "url": "https://api.unsplash.com/search/photos",
        "method": "GET",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{ "name": "Authorization", "value": "=Client-ID {{$VAR.UNSPLASH_KEY}}" }]
        },
        "queryParameters": {
          "parameters": [
            { "name": "query", "value": "={{$json.topic}}" },
            { "name": "per_page", "value": 5 }
          ]
        }
      },
      "id": "unsplash",
      "name": "Recherche Unsplash",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [650, 300]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst results = data.results || [];\nif (results.length === 0) return [{ json: {} }];\n\nconst best = results.reduce((a, b) => (a.likes||0) > (b.likes||0) ? a : b, results[0]);\n\nreturn [{\n  json: {\n    image_url: best.urls?.regular,\n    image_small: best.urls?.small,\n    author: best.user?.name,\n    author_url: best.user?.links?.html,\n    alt: best.alt_description,\n    topic: data.topic\n  }\n}];"
      },
      "id": "best-photo",
      "name": "Meilleure Photo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2.4,
      "position": [850, 300]
    },
    {
      "parameters": {
        "operationMode": "complete",
        "model": "llama3.1:8b",
        "messages": [
          { "role": "system", "content": "Tu génères des carrousels Instagram." },
          { "role": "user", "content": "Génère 5 slides: titre, contenu, caption, hashtags. JSON." }
        ],
        "options": {}
      },
      "id": "ollama",
      "name": "Génère Contenu",
      "type": "ollama.ollamaChat",
      "typeVersion": 1,
      "position": [1050, 300]
    },
    {
      "parameters": {
        "url": "={{$VAR.SUPABASE_URL}}/rest/v1/instagram_drafts",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$VAR.SUPABASE_KEY}}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "topic", "value": "={{$json.topic}}" },
            { "name": "format", "value": "={{$json.format}}" },
            { "name": "slides", "value": "={{$json.slides}}" },
            { "name": "unsplash_image_url", "value": "={{$json.image_url}}" },
            { "name": "status", "value": "draft" }
          ]
        }
      },
      "id": "supabase",
      "name": "Sauvegarde",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1250, 300]
    }
  ],
  "connections": {
    "Planificateur": { "main": [[{"node": "Brief", "type": "main", "index": 0}]] },
    "Brief": { "main": [[{"node": "Recherche Unsplash", "type": "main", "index": 0}]] },
    "Recherche Unsplash": { "main": [[{"node": "Meilleure Photo", "type": "main", "index": 0}]] },
    "Meilleure Photo": { "main": [[{"node": "Génère Contenu", "type": "main", "index": 0}]] },
    "Génère Contenu": { "main": [[{"node": "Sauvegarde", "type": "main", "index": 0}]] }
  },
  "variables": [
    { "id": "UNSPLASH_KEY", "name": "Unsplash", "type": "string", "value": "" },
    { "id": "SUPABASE_URL", "name": "Supabase URL", "type": "string", "value": "" },
    { "id": "SUPABASE_KEY", "name": "Supabase Key", "type": "string", "value": "" },
    { "id": "OLLAMA_URL", "name": "Ollama", "type": "string", "value": "http://localhost:11434" }
  ],
  "trigger": { "type": "schedule" },
  "updatedAt": "2026-04-11T12:00:00Z",
  "versionId": "1"
}
}