# ============================
# Heldonica AI Edge Skills — Variables d'environnement
# ============================
# ATTENTION : Ne jamais committer ce fichier avec de vraies valeurs !
# Copier ce fichier en .env.local et remplir les valeurs

# --- Meta / Instagram & Facebook ---
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_meta_long_lived_token
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id
FACEBOOK_PAGE_ID=your_facebook_page_id

# --- Gmail / Email ---
GMAIL_CLIENT_ID=your_gmail_oauth_client_id
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_ADDRESS=contact@heldonica.fr

# --- WhatsApp Business API ---
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# --- Google Calendar ---
GOOGLE_CALENDAR_ID=primary
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# --- École Émilie (infos fixes) ---
ECOLE_NOM=Ecole Antoine Chantin
ECOLE_ADRESSE=22 rue Antoine Chantin, 75014 Paris
ECOLE_TEL=+33143278900
