{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/home.html",
      "destination": "/home.html"
    },
    {
      "source": "/admin.html",
      "destination": "/admin.html"
    },
    {
      "source": "/cms.html",
      "destination": "/cms.html"
    },
    {
      "source": "/cms-complete.html",
      "destination": "/cms-complete.html"
    },
    {
      "source": "/maintenance.html",
      "destination": "/maintenance.html"
    },
    {
      "source": "/maintenance",
      "destination": "/maintenance.html"
    },
    {
      "source": "/(.*)",
      "destination": "/maintenance.html",
      "has": [
        {
          "type": "query",
          "key": "maintenance",
          "value": "1"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cms/publish-scheduled",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/auto-publish",
      "schedule": "0 10 * * *"
    }
  ]
}
