{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "rewrites": [
    {
      "source": "/maintenance.html",
      "destination": "/maintenance.html"
    },
    {
      "source": "/maintenance",
      "destination": "/maintenance.html"
    },
    {
      "source": "/(.*)",
      "destination": "/maintenance.html",
      "has": [
        {
          "type": "query",
          "key": "maintenance",
          "value": "1"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cms/publish-scheduled",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/auto-publish",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/revalidate-sitemap",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/instagram/cron",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/send-email-sequences",
      "schedule": "0 */2 * * *"
    }
  ]
}
