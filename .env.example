# Groq API - Get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Unsplash - Get at https://unsplash.com/developers
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# N8n Webhook for Dev Agents (AllHands, Jules, Gemini, Perplexity)
NEXT_PUBLIC_N8N_WEBHOOK_URL=http://localhost:5678/webhook/tool-dev-agents
# Instagram Graph API
# Get at https://developers.facebook.com/apps/
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here
