# ===== HELDONICA — Variables d'environnement =====

# ---- Supabase Database ----
# URL publique du projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Clé publique (annon key) - utilisés côté client
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service role (côté serveur ONLY - jamais exposer au client)
SUPABASE_SERVICE_ROLE_KEY=
# Alias alternatif (certains fichiers utilisent ce nom)
SUPABASE_SERVICE_KEY=

# ---- CMS Authentication ----
# Mot de passe principal du CMS admin
CMS_PASSWORD=
# Clé admin pour endpoints newsletter (GET)
CMS_ADMIN_KEY=
# Secret pour signer les sessions CMS
CMS_SESSION_SECRET=
# Alias: JWT_SECRET
JWT_SECRET=

# ---- Email ----
# API key Resend pour les envois d'emails
RESEND_API_KEY=
# Email admin pour recevoir les demandes contact
ADMIN_EMAIL=contact@heldonica.fr

# ---- Analytics ----
# ID propriété Google Analytics 4
GOOGLE_ANALYTICS_PROPERTY_ID=

# ---- Automatisations ----
# URL webhook n8n pour les agents IA (AllHands, Jules, etc.)
NEXT_PUBLIC_N8N_WEBHOOK_URL=
# URL webhook pour publication automatique
CMS_WEBHOOK_URL=
# Secret pour authentifier les cron jobs
CRON_SECRET=
# Webhooks optionnels (discord, slack, n8n custom)
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
N8N_WEBHOOK_URL=
WEBHOOK_CUSTOM=

# ---- LLM / AI ----
# Clef API OpenAI (pour réponses IA)
OPENAI_API_KEY=
# Alternative: Google Gemini
GEMINI_API_KEY=
# Alternative: Groq (gratuit)
GROQ_API_KEY=
# Clef API pour agent IA custom
AI_AGENT_API_KEY=
# Modèle Ollama (local)
OLLAMA_MODEL=llama3
# URL Ollama (local)
OLLAMA_URL=http://localhost:11434
# Clef API Jules (Google agent)
JULES_API_KEY=

# ---- Images ----
# Access key Unsplash
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=
# IDs/keys Unsplash optionnels
UNSPLASH_APP_ID=
UNSPLASH_SECRET_KEY=
# API key Beholder pour flux Instagram
BEHOLD_API_KEY=
# Feed ID Behold.so pour le flux Instagram (composant InstagramFeed)
NEXT_PUBLIC_BEHOLD_FEED_ID=
# Username Instagram fallback
INSTAGRAM_USERNAME=heldonica
# Instagram API tokens
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ---- Email marketing ----
# API key Brevo (ex Sendinblue) pour newsletter
BREVO_API_KEY=

# ---- Cloud integrations ----
# Google OAuth (Photos API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# iDrive OAuth
IDRIVE_CLIENT_ID=
IDRIVE_CLIENT_SECRET=
# URL publique du site (pour OAuth callbacks)
NEXT_PUBLIC_SITE_URL=https://www.heldonica.fr

# ---- S3 / AWS Storage ----
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# ---- MongoDB (legacy optionnel) ----
MONGODB_URI=

# ---- Node env ----
NODE_ENV=development
